def add_contact():
    print("\n── Добавить контакт ──")
    username   = input("Username: ").strip()
    first_name = input("Имя: ").strip()
    last_name  = input("Фамилия: ").strip()
    email      = input("Email: ").strip()
    birthday   = input("День рождения (YYYY-MM-DD, или Enter): ").strip()
    group      = input("Группа (Family/Work/Friend/Other): ").strip() or "Other"
    phone      = input("Номер телефона: ").strip()
    phone_type = input("Тип телефона (home/work/mobile): ").strip() or "mobile"

    if not username:
        print("Username обязателен!")
        return

    if not birthday:
        birthday = None


    cur.execute("SELECT id FROM groups WHERE name = %s", (group,))
    row = cur.fetchone()
    if row:
        group_id = row[0]
    else:
        cur.execute("INSERT INTO groups (name) VALUES (%s) RETURNING id", (group,))
        group_id = cur.fetchone()[0]
        conn.commit()

  
    try:
        cur.execute(
            "INSERT INTO contacts (username, first_name, last_name, email, birthday, group_id) VALUES (%s, %s, %s, %s, %s, %s)",
            (username, first_name, last_name, email, birthday, group_id)
        )
        conn.commit()
        print("Контакт добавлен!")
    except:
        conn.rollback()
        print("Ошибка: такой username уже существует.")
        return

    
    if phone:
        cur.execute("SELECT id FROM contacts WHERE username = %s", (username,))
        contact_id = cur.fetchone()[0]
        cur.execute(
            "INSERT INTO phones (contact_id, phone, type) VALUES (%s, %s, %s)",
            (contact_id, phone, phone_type)
        )
        conn.commit()



