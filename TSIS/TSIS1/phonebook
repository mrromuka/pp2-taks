    print("  1 - По имени")
    print("  2 - По дню рождения")
    print("  3 - По дате добавления")
    choice = input("Выбор [1]: ").strip() or "1"

    if choice == "1":
        order = "c.username"
    elif choice == "2":
        order = "c.birthday NULLS LAST"
    else:
        order = "c.created_at DESC"

    cur.execute(f"""
        SELECT c.username, c.first_name, c.last_name, c.email, c.birthday,
               g.name, p.phone, p.type
        FROM contacts c
        LEFT JOIN groups g ON g.id = c.group_id
        LEFT JOIN phones p ON p.contact_id = c.id
        ORDER BY {order}
    """)

    rows = cur.fetchall()
    if not rows:
        print("Контактов нет.")
        return

    for row in rows:
        username, first_name, last_name, email, birthday, group, phone, phone_type = row
        print(f"  {username} | {first_name} {last_name} | {email} | {birthday} | {group} | {phone} ({phone_type})")


def paginate():
    print("\n── Постраничный просмотр ──")
    try:
        page_size = int(input("Размер страницы [5]: ").strip() or "5")
    except ValueError:
        page_size = 5

    cur.execute("SELECT COUNT(*) FROM contacts")
    total = cur.fetchone()[0]

    if total == 0:
        print("Контактов нет.")
        return

    page = 0
    total_pages = (total + page_size - 1) // page_size

    while True:
        offset = page * page_size
        cur.execute("""
            SELECT c.username, c.first_name, c.last_name, c.email, c.birthday,
                   g.name, p.phone, p.type
            FROM contacts c
            LEFT JOIN groups g ON g.id = c.group_id
            LEFT JOIN phones p ON p.contact_id = c.id
            ORDER BY c.username
            LIMIT %s OFFSET %s
        """, (page_size, offset))

        rows = cur.fetchall()
        print(f"\n  Страница {page + 1} из {total_pages}:")
        for row in rows:
            username, first_name, last_name, email, birthday, group, phone, phone_type = row
            print(f"  {username} | {first_name} {last_name} | {phone} ({phone_type})")

        nav = input("\n  [n]след  [p]пред  [q]выход: ").strip().lower()
        if nav == "n":
            if page + 1 < total_pages:
                page += 1
            else:
                print("  Это последняя страница.")
        elif nav == "p":
            if page > 0:
                page -= 1
            else:
                print("  Это первая страница.")
        elif nav == "q":
            break



