def move_to_group():
    print("\n── Переместить в группу ──")
    username   = input("Username: ").strip()
    group_name = input("Группа: ").strip()

    if not username or not group_name:
        print("Username и группа обязательны.")
        return

    
    cur.execute("SELECT id FROM groups WHERE name = %s", (group_name,))
    row = cur.fetchone()
    if row:
        group_id = row[0]
    else:
        cur.execute("INSERT INTO groups (name) VALUES (%s) RETURNING id", (group_name,))
        group_id = cur.fetchone()[0]
        conn.commit()

    cur.execute("UPDATE contacts SET group_id = %s WHERE username = %s", (group_id, username))
    if cur.rowcount == 0:
        conn.rollback()
        print("Контакт не найден.")
    else:
        conn.commit()
        print(f"Контакт перемещён в группу '{group_name}'.")



def export_json():
    print("\n── Экспорт в JSON ──")
    filepath = input("Имя файла [contacts.json]: ").strip() or "contacts.json"

    cur.execute("""
        SELECT c.id, c.username, c.first_name, c.last_name,
               c.email, c.birthday, g.name
        FROM contacts c
        LEFT JOIN groups g ON g.id = c.group_id
        ORDER BY c.username
    """)
    contacts = cur.fetchall()

    result = []
    for contact in contacts:
        cid, username, first_name, last_name, email, birthday, group = contact

        cur.execute("SELECT phone, type FROM phones WHERE contact_id = %s", (cid,))
        phones = cur.fetchall()

        phones_list = []
        for p in phones:
            phones_list.append({"phone": p[0], "type": p[1]})

        result.append({
            "username"  : username,
            "first_name": first_name,
            "last_name" : last_name,
            "email"     : email,
            "birthday"  : str(birthday) if birthday else None,
            "group"     : group,
            "phones"    : phones_list
        })

    with open(filepath, "w", encoding="utf-8") as f:
        json.dump(result, f, indent=2, ensure_ascii=False)

    print(f"Экспортировано {len(result)} контактов в '{filepath}'.")



def import_json():
    print("\n── Импорт из JSON ──")
    filepath = input("Имя файла [contacts.json]: ").strip() or "contacts.json"

    try:
        with open(filepath, "r", encoding="utf-8") as f:
            records = json.load(f)
    except FileNotFoundError:
        print("Файл не найден.")
        return

    for rec in records:
        username = (rec.get("username") or "").strip()
        if not username:
            continue

        
        cur.execute("SELECT id FROM contacts WHERE username = %s", (username,))
        existing = cur.fetchone()

        if existing:
            choice = input(f"  '{username}' уже существует. (s)пропустить / (o)перезаписать: ").strip().lower()
            if choice != "o":
                print(f"  Пропущен: {username}")
                continue
        
            cur.execute("DELETE FROM contacts WHERE username = %s", (username,))
            conn.commit()

        
        group_name = rec.get("group") or "Other"
        cur.execute("SELECT id FROM groups WHERE name = %s", (group_name,))
        row = cur.fetchone()
        if row:
            group_id = row[0]
        else:
            cur.execute("INSERT INTO groups (name) VALUES (%s) RETURNING id", (group_name,))
            group_id = cur.fetchone()[0]
            conn.commit()

        
        cur.execute(
            "INSERT INTO contacts (username, first_name, last_name, email, birthday, group_id) VALUES (%s,%s,%s,%s,%s,%s)",
            (username, rec.get("first_name"), rec.get("last_name"),
             rec.get("email"), rec.get("birthday"), group_id)
        )
        conn.commit()

        cur.execute("SELECT id FROM contacts WHERE username = %s", (username,))
        contact_id = cur.fetchone()[0]
        for ph in rec.get("phones", []):
            ptype = ph.get("type", "mobile")
            if ptype not in ("home", "work", "mobile"):
                ptype = "mobile"
            cur.execute(
                "INSERT INTO phones (contact_id, phone, type) VALUES (%s,%s,%s)",
                (contact_id, ph.get("phone", ""), ptype)
            )
        conn.commit()
        print(f"  Добавлен: {username}")

    print("Импорт завершён.")



def import_csv():
    print("\n── Импорт из CSV ──")
    filepath = input("Имя файла [contacts.csv]: ").strip() or "contacts.csv"

    try:
        with open(filepath, newline="", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            rows = list(reader)
    except FileNotFoundError:
        print("Файл не найден.")
        return

    inserted = 0
    for row in rows:
        username = (row.get("username") or "").strip()
        if not username:
            continue

        group_name = (row.get("group") or "Other").strip()
        cur.execute("SELECT id FROM groups WHERE name = %s", (group_name,))
        g = cur.fetchone()
        if g:
            group_id = g[0]
        else:
            cur.execute("INSERT INTO groups (name) VALUES (%s) RETURNING id", (group_name,))
            group_id = cur.fetchone()[0]
            conn.commit()

        birthday = (row.get("birthday") or "").strip() or None
        email    = (row.get("email") or "").strip() or None

        try:
            cur.execute(
                "INSERT INTO contacts (username, first_name, last_name, email, birthday, group_id) VALUES (%s,%s,%s,%s,%s,%s) ON CONFLICT (username) DO NOTHING",
                (username, row.get("first_name"), row.get("last_name"), email, birthday, group_id)
            )
            conn.commit()
        except:
            conn.rollback()
            continue

        phone      = (row.get("phone") or "").strip()
        phone_type = (row.get("phone_type") or "mobile").strip()
        if phone_type not in ("home", "work", "mobile"):
            phone_type = "mobile"

        if phone:
            cur.execute("SELECT id FROM contacts WHERE username = %s", (username,))
            cid = cur.fetchone()
            if cid:
                cur.execute(
                    "INSERT INTO phones (contact_id, phone, type) VALUES (%s,%s,%s)",
                    (cid[0], phone, phone_type)
                )
                conn.commit()

        inserted += 1
        print(f"  Добавлен: {username}")

    print(f"Импорт из CSV завершён: {inserted} контактов.")



def delete_contact():
    print("\n── Удалить контакт ──")
    username = input("Username: ").strip()
    if not username:
        return

    cur.execute("SELECT id FROM contacts WHERE username = %s", (username,))
    row = cur.fetchone()
    if not row:
        print("Контакт не найден.")
        return

    confirm = input(f"Удалить '{username}'? (y/n): ").strip().lower()
    if confirm == "y":
        cur.execute("DELETE FROM contacts WHERE username = %s", (username,))
        conn.commit()
        print("Удалён.")
    else:
        print("Отменено.")



