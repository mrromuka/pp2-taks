def search():
    print("\n── Поиск ──")
    query = input("Введите имя, email или телефон: ").strip()
    if not query:
        return

    pattern = "%" + query + "%"

    cur.execute("""
        SELECT c.username, c.first_name, c.last_name, c.email, c.birthday,
               g.name, p.phone, p.type
        FROM contacts c
        LEFT JOIN groups g ON g.id = c.group_id
        LEFT JOIN phones p ON p.contact_id = c.id
        WHERE c.username   ILIKE %s
           OR c.first_name ILIKE %s
           OR c.last_name  ILIKE %s
           OR c.email      ILIKE %s
           OR p.phone      ILIKE %s
        ORDER BY c.username
    """, (pattern, pattern, pattern, pattern, pattern))

    rows = cur.fetchall()
    if not rows:
        print("Ничего не найдено.")
        return

    for row in rows:
        username, first_name, last_name, email, birthday, group, phone, phone_type = row
        print(f"  {username} | {first_name} {last_name} | {email} | {birthday} | {group} | {phone} ({phone_type})")



def filter_by_group():
    print("\n── Фильтр по группе ──")
    group = input("Название группы (Family/Work/Friend/Other): ").strip()
    if not group:
        return

    cur.execute("""
        SELECT c.username, c.first_name, c.last_name, c.email, c.birthday,
               g.name, p.phone, p.type
        FROM contacts c
        LEFT JOIN groups g ON g.id = c.group_id
        LEFT JOIN phones p ON p.contact_id = c.id
