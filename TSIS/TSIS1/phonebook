    cur.execute("""
        SELECT c.username, c.first_name, c.last_name, c.email, c.birthday,
               g.name, p.phone, p.type
        FROM contacts c
        LEFT JOIN groups g ON g.id = c.group_id
        LEFT JOIN phones p ON p.contact_id = c.id
        ORDER BY c.username
    """)
    rows = cur.fetchall()

